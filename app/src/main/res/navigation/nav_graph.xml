<?xml version="1.0" encoding="utf-8"?>
<!-- ── 🌟 NAV GRAPH EDUTRACK ASLI: SINKRONISASI ARSITEKTUR FRAGMENT & ACTIVITY ── -->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- 1. AUTH DESTINATIONS -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.edutrack.ui.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment"/>
        <action
            android:id="@+id/action_loginFragment_to_resetPasswordFragment"
            app:destination="@id/resetPasswordFragment"/>
        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.edutrack.ui.auth.RegisterFragment"
        android:label="Register"/>

    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="com.example.edutrack.ui.auth.ResetPasswordFragment"
        android:label="Reset Password"/>

    <!-- 2. CORE DASHBOARD FRAGMENT -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.edutrack.ui.dashboard.DashboardFragment"
        android:label="Dashboard" >
        <action
            android:id="@+id/action_dashboardFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/dashboardFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_dashboardFragment_to_jadwalFragment"
            app:destination="@id/jadwalFragment" />
    </fragment>

    <!-- 3. CORE JADWAL FRAGMENT -->
    <fragment
        android:id="@+id/jadwalFragment"
        android:name="com.example.edutrack.ui.jadwal.JadwalFragment"
        android:label="fragment_jadwal"
        tools:layout="@layout/fragment_jadwal" />

    <!-- 🔥 4. REVISI UTAMA: STRUKTUR TAG FRAGMENT POMODORO YANG BENAR & VALID -->
    <fragment
        android:id="@+id/pomodoroTimerActivity"
        android:name="com.example.edutrack.ui.pomodoro.PomodoroTimerFragment"
        android:label="Pomodoro Timer"
        tools:layout="@layout/fragment_pomodoro_timer" />

    <!-- 5. TEMPORARY FLASHCARD ACTIVITY DESTINATION -->
    <fragment
        android:id="@+id/flashcardActivity"
        android:name="com.example.edutrack.ui.flashcard.FlashcardFragment"
        android:label="Flashcard"
        tools:layout="@layout/fragment_flashcard" />
</navigation>